# ===== FEATURE FLAGS =====
# Non-Riot features
FF_HELP=true
FF_FUN_GAMES=true
FF_LFG=true
FF_MISSIONS=true
FF_TOURNAMENTS=true

# Riot API only
FF_VAL_CONTENT=true
FF_VAL_STATUS=true
