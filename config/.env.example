# ===== DATABASE =====
MONGO_URI=mongodb://127.0.0.1:27017/academy_drix_valorant

# ===== RIOT (boleh kosong dulu untuk sementara) =====
RIOT_API_KEY=
RIOT_RSO_CLIENT_ID=
