# ==========================================
#        ACADEMY DRIX VALORANT BOT
#          ENVIRONMENT VARIABLES
# ==========================================

# ===== DISCORD BOT CONFIGURATION =====
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_GUILD_ID=your_test_guild_id_here


# ===== BOT SETTINGS =====
# Waktu tenggat check peringatan LFG (dalam menit)
LFG_TIMEOUT_MINUTES=60

# ===== DATABASE CONFIGURATION =====
MONGO_URI=mongodb://127.0.0.1:27017/academy_drix_valorant
MONGO_DB_NAME=academy_drix_global

# ===== API CONFIGURATION (RIOT GAMES) =====
RIOT_API_KEY=
RIOT_API_KEY_TYPE=development

# ===== RSO CONFIGURATION (HANYA UNTUK PRODUCTION) =====
RIOT_RSO_ENABLED=false
RIOT_RSO_CLIENT_ID=
RIOT_RSO_CLIENT_SECRET=
RIOT_RSO_REDIRECT_URI=http://localhost:3000/callback

# ===== FEATURE FLAGS (TOGGLES) =====
# --- General Features ---
FF_WELCOME_MESSAGE=true
FF_HELP=true
FF_FUN_GAMES=true
FF_LFG=true
FF_MISSIONS=true
FF_TOURNAMENTS=true

# --- Riot API + RSO Features (Production Only) ---
FEATURE_LINK_ACCOUNT=true
FEATURE_PROFILE=true
FEATURE_RANK=true
FEATURE_STATS=true
FEATURE_MATCH_HISTORY=true
FEATURE_LEADERBOARD_API=true

# --- Discord Role Features ---
FEATURE_LEADERBOARD_ROLE=true
